---
import '../index.css';
import { Navbar } from '../components/Navbar';
import { Footer } from '../components/Footer';

interface Props {
  title?: string;
  active?: string;
}

const {
  title = "Kapara — Toronto's Best Casual Kosher Spot",
  active = 'home',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <div id="app-root" class="flex flex-col bg-brand-cream/10 min-h-screen">
      <Navbar client:load activePage={active} />
      <main id="main-content-canvas" class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
